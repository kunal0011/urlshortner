# ─────────────────────────────────────────
# Global
# ─────────────────────────────────────────
ENVIRONMENT=dev
LOG_LEVEL=info
BASE_SHORT_URL=http://localhost:8080
SENTRY_DSN=

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=urlshortner
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urlshortner

# ─────────────────────────────────────────
# Redis (hot path cache)
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis (session / rate-limiting)
REDIS_SESSION_HOST=localhost
REDIS_SESSION_PORT=6380
REDIS_SESSION_PASSWORD=
REDIS_SESSION_DB=0

# ─────────────────────────────────────────
# Kafka
# ─────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_CLICK_EVENTS=click-events
KAFKA_CONSUMER_GROUP=analytics-ingest

# ─────────────────────────────────────────
# ClickHouse
# ─────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=analytics

# ─────────────────────────────────────────
# Auth – Keycloak
# ─────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8090
KEYCLOAK_REALM=urlshortner
KEYCLOAK_CLIENT_ID=url-api-svc
KEYCLOAK_CLIENT_SECRET=
JWT_SECRET=change-me-to-a-long-random-string-256-bits

# ─────────────────────────────────────────
# AWS / S3
# ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_QR_CODES=urlshortner-qr-codes
CLOUDFRONT_DOMAIN=https://cdn.example.com

# ─────────────────────────────────────────
# Temporal
# ─────────────────────────────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# ─────────────────────────────────────────
# OpenSearch (admin search)
# ─────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# ─────────────────────────────────────────
# Security
# ─────────────────────────────────────────
GOOGLE_SAFE_BROWSING_API_KEY=
RATE_LIMIT_ANON_PER_HOUR=100
RATE_LIMIT_AUTH_PER_HOUR=10000

# ─────────────────────────────────────────
# Billing (Stripe)
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FREE_PLAN_ID=
STRIPE_PRO_PLAN_ID=
STRIPE_ENTERPRISE_PLAN_ID=

# ─────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@urlshortner.example.com

# ─────────────────────────────────────────
# Slack
# ─────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ─────────────────────────────────────────
# Service Ports
# ─────────────────────────────────────────
REDIRECT_SVC_PORT=8080
URL_API_SVC_PORT=8081
ANALYTICS_INGEST_SVC_PORT=8082
ANALYTICS_QUERY_SVC_PORT=8083
USER_ORG_SVC_PORT=8084
QR_SVC_PORT=8085
NOTIFICATION_SVC_PORT=8086
ADMIN_SVC_PORT=8087
